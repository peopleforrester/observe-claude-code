# ABOUTME: Telemetry env for pointing a local Claude Code session at the demo Collector.
# ABOUTME: Source before launching `claude`. No secrets here — safe to commit.

# Enable telemetry collection.
export CLAUDE_CODE_ENABLE_TELEMETRY=1

# Metrics + events over OTLP. Traces are enabled separately below.
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp

# Send to the local Collector over gRPC.
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Faster intervals so the stage demo moves within a few seconds (defaults 60000 / 5000).
export OTEL_METRIC_EXPORT_INTERVAL=10000
export OTEL_LOGS_EXPORT_INTERVAL=2000

# Prometheus expects cumulative; Claude Code defaults to delta.
export OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative

# Tool + MCP detail for the security pane (off by default).
export OTEL_LOG_TOOL_DETAILS=1

# Traces (beta): the prompt -> tool -> MCP waterfall.
export CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
export OTEL_TRACES_EXPORTER=otlp

# Attribute the session to a role for the "good by role" framing.
export OTEL_RESOURCE_ATTRIBUTES=role=backend,team.id=demo,cost_center=agntcon

# Deliberately NOT set — collect identity and decisions, not content:
#   OTEL_LOG_USER_PROMPTS, OTEL_LOG_TOOL_CONTENT, OTEL_LOG_RAW_API_BODIES
